generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String?
  calorieBound     Int       @default(2000)
  dietaryPreference String   @default("Omnivore") // Omnivore, Vegetarian, Vegan, Keto
  onboardingComplete Boolean @default(false)
  
  // TDEE & Demographics
  age              Int?
  heightCm         Float?
  weightKg         Float?
  gender           String?
  activityLevel    String?
  
  // Macro Targets
  proteinGoalG     Int?
  carbsGoalG       Int?
  fatGoalG         Int?
  
  // Streaks & Time
  currentStreak    Int       @default(0)
  lastStreakDate   DateTime?
  timezone         String    @default("UTC")

  // New Goals
  waterGoalMl      Int       @default(2000)

  mealLogs         MealLog[]
  customFoods      CustomFood[]
  waterLogs        WaterLog[]
  weightLogs       WeightLog[]
  exerciseLogs     ExerciseLog[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model MealLog {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String     // Breakfast, Lunch, Dinner, Snack
  date        DateTime   @default(now())
  items       FoodItem[]
}

model FoodItem {
  id             String   @id @default(cuid())
  mealLogId      String
  mealLog        MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  name           String
  calories       Int
  protein        Float?
  carbs          Float?
  fat            Float?
  servingSizeG   Float?
}

model CustomFood {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  calories       Int
  protein        Float?
  carbs          Float?
  fat            Float?
  servingSizeG   Float?
  isFavorite     Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model LocalFoodDictionary {
  id             String   @id @default(cuid())
  name           String   @unique
  calories       Int
  protein_g      Float
  carbohydrates_total_g Float
  fat_total_g    Float
  serving_size_g Float
}

model WaterLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl    Int
  date        DateTime @default(now())
}

model WeightLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg    Float
  date        DateTime @default(now())
}

model ExerciseLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityName   String
  durationMin    Int
  caloriesBurned Int
  date           DateTime @default(now())
}
